FROM python:3.10-slim 

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Install PyTorch (CPU-only for now, add CUDA if you have GPU access)
RUN pip install --no-cache-dir torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu

# Install FastAPI for the trainer API
RUN pip install --no-cache-dir fastapi uvicorn pydantic

COPY requirements.md /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt && rm /tmp/requirements.txt

COPY trainer/ /workspace/trainer/

ENV PYTHONPATH=/workspace
ENV OLLAMA_BASE_URL=http://192.1688.1.100:11434
ENV CHECKPOINT_DIR=/workspace/checkpoints

CMD ["uvicorn", "trainer.api:app", "--host", "0.0.0.0", "--port", "8090"]
